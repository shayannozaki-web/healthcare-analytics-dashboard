# Anthropic API key for the /ask query interface.
# Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Turso (libSQL) connection — leave both blank for local dev (uses ./data/healthcare.db).
# Get these from `turso db show <db>` and `turso db tokens create <db>`.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
